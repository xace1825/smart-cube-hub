{
  "name": "@optique/run",
  "version": "1.1.1",
  "description": "Type-safe combinatorial command-line interface parser",
  "keywords": [
    "CLI",
    "command-line",
    "commandline",
    "parser",
    "getopt",
    "optparse"
  ],
  "license": "MIT",
  "author": {
    "name": "Hong Minhee",
    "email": "hong@minhee.org",
    "url": "https://hongminhee.org/"
  },
  "homepage": "https://optique.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dahlia/optique.git",
    "directory": "packages/run/"
  },
  "bugs": {
    "url": "https://github.com/dahlia/optique/issues"
  },
  "funding": [
    "https://github.com/sponsors/dahlia"
  ],
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.2.0",
    "deno": ">=2.3.0"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.ts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./run": {
      "types": {
        "import": "./dist/run.d.ts",
        "require": "./dist/run.d.cts"
      },
      "import": "./dist/run.js",
      "require": "./dist/run.cjs"
    },
    "./valueparser": {
      "types": {
        "import": "./dist/valueparser.d.ts",
        "require": "./dist/valueparser.d.cts"
      },
      "import": "./dist/valueparser.js",
      "require": "./dist/valueparser.cjs"
    }
  },
  "imports": {
    "#src/*.ts": {
      "node": "./dist/*.js",
      "default": "./src/*.ts"
    }
  },
  "sideEffects": false,
  "dependencies": {
    "@optique/core": "1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "fast-check": "^4.7.0",
    "tsdown": "^0.13.0",
    "typescript": "^5.8.3",
    "@optique/config": "1.1.1",
    "@optique/env": "1.1.1"
  },
  "scripts": {
    "build": "tsdown",
    "prepublish": "tsdown",
    "test": "node --test",
    "test:bun": "bun test",
    "test:deno": "deno test",
    "test-all": "tsdown && node --test && bun test && deno test"
  }
}